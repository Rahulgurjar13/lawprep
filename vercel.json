{
  "headers": [
    {
      "source": "/(.*)\\.(js|css|svg|ico|png|jpg|jpeg|webp)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
